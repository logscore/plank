# Database for dev only. Production docker-compose.yml overrides this value
DATABASE_URL=./data/plank.db

# Where the files are saved when downloaded
DATA_PATH=./data

# Docker only: host path mounted as the media library
MEDIA_PATH=../media

# Get yours here https://www.themoviedb.org/settings/api
TMDB_API_KEY=

# Prowlarr (Torrent Search)
PROWLARR_URL=http://localhost:9696
PUBLIC_PROWLARR_URL=http://localhost:9696
# Leave blank when running Plank fully self-hosted; Docker configures this automatically.
PROWLARR_API_KEY=
FLARESOLVERR_URL=http://localhost:8191

# OpenSubtitles (Subtitle Downloads)
# Get API key at https://www.opensubtitles.com/consumers
OPENSUBTITLES_API_KEY=
OPENSUBTITLES_USERNAME=
OPENSUBTITLES_PASSWORD=

# Authentication
BETTER_AUTH_SECRET=super-secret-32-char-string
BETTER_AUTH_URL=http://localhost:3300

PORT=3300
HOST=0.0.0.0
ORIGIN=http://localhost:3300

# This increases the size of the request body in sveltekit, for images, but really we should directly upload to S3
BODY_SIZE_LIMIT=11M
